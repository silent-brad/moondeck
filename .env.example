# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                        MOONDECK CONFIGURATION                                ║
# ║                                                                              ║
# ║  Copy this file to config/.env and fill in your values                      ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ PAGE_SWITCH_INTERVAL (ms)                                                    │
# └──────────────────────────────────────────────────────────────────────────────┘

PAGE_SWITCH_INTERVAL=60000 # 1 minute

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ NETWORK                                                                       │
# └──────────────────────────────────────────────────────────────────────────────┘

WIFI_SSID=your_wifi_ssid
WIFI_PASSWORD=your_wifi_password

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ DISPLAY                                                                       │
# └──────────────────────────────────────────────────────────────────────────────┘

# Theme: dark, light, mint
THEME=dark

# Timezone offset from UTC in hours (e.g., -5 for EST, -4 for EDT, 0 for UTC)
TIMEZONE=-5

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ WEATHER (OpenWeatherMap)                                                      │
# │ Get your free API key at: https://openweathermap.org/api                     │
# └──────────────────────────────────────────────────────────────────────────────┘

WEATHER_API_KEY=your_openweathermap_api_key
WEATHER_CITY=New York
WEATHER_UNITS=imperial

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ STOCKS                                                                    │
# └──────────────────────────────────────────────────────────────────────────────┘

# Comma-separated list of stock symbols
STOCKS_SYMBOLS=AAPL,GOOGL,MSFT,TSLA

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ CRYPTO (CoinGecko - No API key required for basic usage)                     │
# │ Documentation: https://www.coingecko.com/en/api                              │
# └──────────────────────────────────────────────────────────────────────────────┘

# Comma-separated list of coin IDs (use CoinGecko IDs)
CRYPTO_COINS=bitcoin,ethereum,solana
# Currency for prices: usd, eur, gbp, etc.
CRYPTO_CURRENCY=usd

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ RSS / MINIFLUX                                                                │
# │ Self-hosted Miniflux RSS reader                                              │
# └──────────────────────────────────────────────────────────────────────────────┘

MINIFLUX_URL=https://your-miniflux-instance.com
MINIFLUX_API_KEY=your_miniflux_api_key
# Number of entries to fetch
MINIFLUX_LIMIT=10

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ QUOTES                                                                        │
# └──────────────────────────────────────────────────────────────────────────────┘

# Built-in quotes are used by default
# Set to a URL to fetch quotes from an external API
# QUOTES_API_URL=https://api.quotable.io/random

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ GITHUB (GitHub GraphQL API)                                                  │
# │ Generate a token at: https://github.com/settings/tokens                     │
# │ Required scope: read:user                                                    │
# └──────────────────────────────────────────────────────────────────────────────┘

GITHUB_USERNAME=your_github_username
GITHUB_TOKEN=your_github_personal_access_token

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │  CHESS.COM                                                                   │
# └──────────────────────────────────────────────────────────────────────────────┘

CHESS_USERNAME=your_chess_username
